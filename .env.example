# ============================================================
# PULSE — Environment Variables
# Copy to .env and fill in values
# ============================================================

# ---- Database (Supabase) ------------------------------------
# Pooled connection (for Prisma in serverless)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (for Prisma migrations)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ---- Auth (NextAuth v5) -------------------------------------
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# ---- Email Magic Link (Resend) — free tier: 3K/month -------
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="ayoo <noreply@ayoo.app>"

# ---- Merchant App -------------------------------------------
MERCHANT_URL="http://localhost:3001"
# Secret for signing merchant JWT tokens
MERCHANT_AUTH_SECRET="generate-with: openssl rand -base64 32"

# ---- Telegram Bot -------------------------------------------
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN="1234567890:ABCDEFxxxxxxxxxxxxxxxx"
# Bot username (without @) — used in gift share links
TELEGRAM_BOT_USERNAME="ayoo_loyalty_bot"
# Mini App URL for gift link redirects in the bot
MINI_APP_URL="https://ayoo-app.vercel.app"
# Webhook URL for the bot (set to your production API URL + /api/bot)
BOT_WEBHOOK_URL="https://your-domain.com/api/bot"

# ---- Supabase Storage ---------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ---- Mobile App (Expo public env, exposed to client) -------
EXPO_PUBLIC_API_URL="http://localhost:3000"
EXPO_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
EXPO_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# ---- Upstash Redis (free tier: 10K commands/day) -----------
UPSTASH_REDIS_REST_URL="https://[id].upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# ---- Upstash QStash (cron jobs, free: 500 msg/day) ---------
QSTASH_URL="https://qstash.upstash.io"
QSTASH_TOKEN="your-qstash-token"
QSTASH_CURRENT_SIGNING_KEY="your-signing-key"
QSTASH_NEXT_SIGNING_KEY="your-next-signing-key"

# ---- OCR (Google Vision — free: 1K units/month) ------------
GOOGLE_CLOUD_API_KEY="your-google-cloud-api-key"

# ---- OCR Primary (OpenAI GPT-4o) — paid -------------------
OPENAI_API_KEY="sk-xxxxxxxxxxxx"

# ---- AI Verification (Anthropic Claude) — paid -------------
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxx"

# ---- Phone Auth — Tier 2 (Twilio Verify) ------------------
# TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxx"
# TWILIO_AUTH_TOKEN="your-auth-token"
# TWILIO_VERIFY_SERVICE_SID="VAxxxxxxxxxxxx"

# ---- Push Notifications — when mobile app added -----------
# FIREBASE_PROJECT_ID="pulse-app"
# FIREBASE_CLIENT_EMAIL="firebase-adminsdk@pulse-app.iam.gserviceaccount.com"
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."
