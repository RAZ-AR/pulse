{
  "expo": {
    "name": "PULSE",
    "slug": "pulse",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "pulse",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pulse.app"
    },
    "android": {
      "package": "com.pulse.app",
      "adaptiveIcon": {
        "backgroundColor": "#0F1115"
      }
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-secure-store",
      [
        "expo-location",
        { "locationAlwaysAndWhenInUsePermission": "Allow PULSE to use your location to show nearby partner venues." }
      ],
      [
        "expo-camera",
        { "cameraPermission": "Allow PULSE to use the camera to scan receipts and check in at venues." }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
