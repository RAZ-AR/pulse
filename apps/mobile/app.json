{
  "expo": {
    "name": "ayoo",
    "slug": "ayoo",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "pulse",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pulse.app"
    },
    "android": {
      "package": "com.pulse.app",
      "adaptiveIcon": {
        "backgroundColor": "#0F1115"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow ayoo to use your location to show nearby partner venues."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow ayoo to use the camera to scan receipts and check in at venues."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0F1115",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "ce9ee81f-84dc-43ff-8609-3b47205c4101"
      }
    },
    "owner": "bari_lus"
  }
}
