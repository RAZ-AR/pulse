{
  "name": "ayoo-backend",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "db:generate": "turbo db:generate",
    "db:migrate": "pnpm --filter @pulse/db db:migrate",
    "db:migrate:prod": "pnpm --filter @pulse/db db:migrate:prod",
    "db:studio": "pnpm --filter @pulse/db db:studio",
    "db:seed": "pnpm --filter @pulse/db db:seed",
    "db:import:venues": "pnpm --filter @pulse/db db:import:venues",
    "db:fetch:google-venues": "pnpm --filter @pulse/db db:fetch:google-venues",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.15",
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0"
}
